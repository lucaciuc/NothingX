<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nothing Color Palette -->
    <Color x:Key="NothingBlack">#0B0B0B</Color>
    <Color x:Key="NothingPureBlack">#000000</Color>
    <Color x:Key="NothingDarkGray">#1A1A1A</Color>
    <Color x:Key="NothingButtonGray">#282828</Color>
    <Color x:Key="NothingLightGray">#888888</Color>
    <Color x:Key="NothingWhite">#FFFFFF</Color>
    <Color x:Key="NothingRed">#E60000</Color>

    <SolidColorBrush x:Key="BrushBlack" Color="{StaticResource NothingBlack}"/>
    <SolidColorBrush x:Key="BrushPureBlack" Color="{StaticResource NothingPureBlack}"/>
    <SolidColorBrush x:Key="BrushDarkGray" Color="{StaticResource NothingDarkGray}"/>
    <SolidColorBrush x:Key="BrushButtonGray" Color="{StaticResource NothingButtonGray}"/>
    <SolidColorBrush x:Key="BrushLightGray" Color="{StaticResource NothingLightGray}"/>
    <SolidColorBrush x:Key="BrushWhite" Color="{StaticResource NothingWhite}"/>
    <SolidColorBrush x:Key="BrushRed" Color="{StaticResource NothingRed}"/>

    <!-- Common Styles -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BrushBlack}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <!-- Serif font for the device title -->
    <Style x:Key="DeviceTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontFamily" Value="Georgia, Times New Roman, Serif"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,20,0,5"/>
    </Style>

    <Style x:Key="HeadingText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="20,20,20,15"/>
    </Style>
    
    <Style x:Key="SubHeadingText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushLightGray}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>

    <!-- Dot Matrix Style fallback for subtext -->
    <Style x:Key="DotMatrixText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushLightGray}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Consolas, Courier New, Monospace"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,30,0,10"/>
    </Style>

    <!-- Card Border Style -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushDarkGray}"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Margin" Value="15,10"/>
        <Setter Property="Padding" Value="0,0,0,20"/>
    </Style>

    <!-- Standard Button -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushRed}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                            CornerRadius="25" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4"/>
                            <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BrushButtonGray}"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.1" />
                                    <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1" />
                                    <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ANC Circular Toggle Button -->
    <Style x:Key="AncToggleButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="Background" Value="{StaticResource BrushButtonGray}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="95"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="GroupName" Value="AncModes"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel>
                        <!-- Circular Button -->
                        <Border x:Name="CircBorder" Width="60" Height="60" CornerRadius="30" Background="{TemplateBinding Background}" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <TextBlock x:Name="IconText" Text="{TemplateBinding Tag}" FontSize="24" Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <!-- Label below -->
                        <TextBlock x:Name="LabelText" Text="{TemplateBinding Content}" FontSize="12" Foreground="{StaticResource BrushLightGray}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CircBorder" Property="Background" Value="{StaticResource BrushWhite}"/>
                            <Setter TargetName="LabelText" Property="Foreground" Value="{StaticResource BrushWhite}"/>
                            <Setter TargetName="LabelText" Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushBlack}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CircBorder" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="CircBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1" />
                                    <DoubleAnimation Storyboard.TargetName="CircBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="CircBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="CircBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Equalizer Preset Button -->
    <Style x:Key="EqPresetButton" TargetType="RadioButton">
        <Setter Property="Background" Value="{StaticResource BrushButtonGray}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushLightGray}"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="GroupName" Value="EqPresets"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="25" RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BrushWhite}"/>
                            <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource BrushBlack}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1" />
                                    <DoubleAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Custom Red Slider for EQ -->
    <Style TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource BrushDarkGray}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Border Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto" MinWidth="{TemplateBinding MinWidth}"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Track -->
                            <Border x:Name="TrackBackground" Grid.Column="1" Width="4" Margin="0,10" Background="{StaticResource BrushButtonGray}" CornerRadius="2" HorizontalAlignment="Center"/>
                            
                            <!-- Red Fill (from thumb down) -->
                            <Border x:Name="TrackFill" Grid.Column="1" Width="4" Margin="0,10" Background="{StaticResource BrushRed}" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>

                            <Track x:Name="PART_Track" Grid.Column="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{x:Null}" Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{x:Null}" Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="16" Height="16" Background="{StaticResource BrushWhite}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </Border>
                    <!-- In a real implementation for a vertical slider, the fill rectangle needs proper binding to calculate height. For simplicity we assume a standard track fill behavior or rely on Thumb position. WPF default vertical slider track doesn't naturally fill bottom-up without extra elements, but this minimalist style handles the thumb. -->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bass Enhancer Slider Style with T-shaped Thumb -->
    <Style x:Key="BassEnhancerSliderStyle" TargetType="Slider">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Border Background="Transparent">
                        <Grid VerticalAlignment="Bottom" Height="22">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{x:Null}" Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{x:Null}" Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="14" Height="22" Background="{StaticResource BrushWhite}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Background="Transparent">
                                                    <Border Width="14" Height="4" Background="{TemplateBinding Background}" CornerRadius="2" VerticalAlignment="Top"/>
                                                    <Border Width="4" Height="18" Background="{TemplateBinding Background}" CornerRadius="2" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- EQ Tab Button -->
    <Style x:Key="EqTabButton" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushLightGray}"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="GroupName" Value="EqTabs"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                        <TextBlock x:Name="Txt" Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Margin="10,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BrushRed}"/>
                            <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource BrushWhite}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource BrushWhite}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sleek Rounded Toggle Switch -->
    <Style x:Key="CustomToggleSwitchStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource BrushDarkGray}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushButtonGray}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Width" Value="50"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="13">
                        <Ellipse x:Name="Knob" 
                                 Fill="{StaticResource BrushLightGray}" 
                                 Width="18" 
                                 Height="18" 
                                 HorizontalAlignment="Left" 
                                 Margin="2,0,0,0">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BrushRed}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BrushRed}"/>
                            <Setter TargetName="Knob" Property="Fill" Value="{StaticResource BrushWhite}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Knob" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                         To="24" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Knob" 
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                         To="0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox Item Style -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushButtonGray}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushRed}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox Style -->
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="Background" Value="{StaticResource BrushButtonGray}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" 
                                      Background="{TemplateBinding Background}" 
                                      Foreground="{TemplateBinding Foreground}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="18" Padding="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <Grid>
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            <TextBlock Text="▼" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" Foreground="{StaticResource BrushLightGray}"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                            <Border Background="{StaticResource BrushDarkGray}" BorderBrush="{StaticResource BrushButtonGray}" BorderThickness="1" CornerRadius="12" Margin="0,5,0,0" MaxHeight="200" MinWidth="{Binding ActualWidth, ElementName=ToggleButton}">
                                <ScrollViewer Margin="0,5">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox Item Style -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushButtonGray}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushRed}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox Style -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource BrushDarkGray}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushWhite}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="5">
                        <ScrollViewer>
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Minimal ScrollBar Style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource BrushButtonGray}" CornerRadius="4" Margin="2,0"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
