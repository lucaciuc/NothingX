<Window x:Class="NothingX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NothingX"
        xmlns:viewmodels="clr-namespace:NothingX.ViewModels"
        xmlns:controls="clr-namespace:NothingX.Controls"
        mc:Ignorable="d"
        Title="Nothing X" Height="800" Width="450"
        WindowStyle="None" AllowsTransparency="False" Background="{StaticResource BrushBlack}"
        WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <local:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
    </Window.Resources>

    <!-- App Container -->
    <Border Background="{StaticResource BrushBlack}" BorderBrush="{StaticResource BrushDarkGray}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar for Dragging -->
            <Grid Grid.Row="0" Height="40" Background="Transparent">
                <TextBlock Text="Nothing X" Foreground="{StaticResource BrushLightGray}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <!-- Window Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="−" Width="40" Background="Transparent" Foreground="{StaticResource BrushLightGray}" Click="MinimizeButton_Click" Padding="0"/>
                    <Button Content="⬜" Width="40" Background="Transparent" Foreground="{StaticResource BrushLightGray}" Click="MaximizeButton_Click" Padding="0" FontSize="10"/>
                    <Button Content="✕" Width="40" Background="Transparent" Foreground="{StaticResource BrushLightGray}" Click="CloseButton_Click" Padding="0"/>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1">
                
                <!-- CONNECT VIEW -->
                <Grid Visibility="{Binding SelectedDeviceView, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Connect}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                        <TextBlock Text="Connect Device" Style="{StaticResource DeviceTitleText}"/>
                        <TextBlock Text="Ensure your earbuds are paired in Windows Bluetooth settings." TextWrapping="Wrap" Style="{StaticResource SubHeadingText}" TextAlignment="Center" Margin="0,0,0,30"/>
                        
                        <Button Content="Scan for Devices" Command="{Binding ScanDevicesCommand}" Margin="0,0,0,20"/>
                        
                        <ListBox ItemsSource="{Binding DiscoveredDevices}" MinHeight="150" MaxHeight="300" Margin="0,10"
                                 SelectedItem="{Binding SelectedDevice, Mode=TwoWay}" Background="{StaticResource BrushDarkGray}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="10">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding Address}" Style="{StaticResource SubHeadingText}" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Connect" Command="{Binding ConnectToDeviceCommand}" CommandParameter="{Binding SelectedDevice}"
                                IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBooleanConverter}}" Margin="0,20,0,0"/>
                        
                        <ProgressBar IsIndeterminate="True" Height="4" Margin="0,20" Foreground="{StaticResource BrushWhite}" Background="{StaticResource BrushDarkGray}" BorderThickness="0" Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>

                <!-- DEVICE VIEW -->
                <Grid Visibility="{Binding SelectedDeviceView, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Device}">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,0,0,20">
                        <StackPanel>
                            <!-- Header: Image and Title -->
                            <TextBlock Text="{Binding Device.Name}" Style="{StaticResource DeviceTitleText}"/>
                            
                            <!-- Battery Row -->
                            <Grid HorizontalAlignment="Center" Margin="0,5,0,20">
                                <!-- Headphones (Single Battery) -->
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHeadphone}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="⚡" Foreground="LightGreen" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Device.Battery.Case, StringFormat='{}{0}%'}" Foreground="{StaticResource BrushLightGray}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Earbuds (L, R, Case) -->
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHeadphone}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <TextBlock Text="L" Foreground="{StaticResource BrushWhite}" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Device.Battery.Left, StringFormat='{}{0}%'}" Foreground="{StaticResource BrushLightGray}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    
                                    <TextBlock Text="R" Foreground="{StaticResource BrushWhite}" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Device.Battery.Right, StringFormat='{}{0}%'}" Foreground="{StaticResource BrushLightGray}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                    <TextBlock Text="Case" Foreground="{StaticResource BrushWhite}" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Device.Battery.Case, StringFormat='{}{0}%'}" Foreground="{StaticResource BrushLightGray}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Debug Status Text -->
                            <TextBlock Text="{Binding StatusText}" Foreground="Yellow" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Noise Cancellation Card -->
                            <Border Style="{StaticResource CardBorder}" Margin="15,20">
                                <StackPanel>
                                    <TextBlock Text="Noise cancellation" Style="{StaticResource HeadingText}" Margin="20,20,20,25"/>
                                    <Grid Margin="10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <RadioButton Grid.Column="0" Content="On" Tag="○" Command="{Binding SetAncModeCommand}" CommandParameter="NoiseCancellation" Style="{StaticResource AncToggleButton}" IsChecked="{Binding Device.AncMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=NoiseCancellation, Mode=OneWay}"/>
                                        <RadioButton Grid.Column="1" Content="Transparency" Tag="⋮" Command="{Binding SetAncModeCommand}" CommandParameter="Transparency" Style="{StaticResource AncToggleButton}" IsChecked="{Binding Device.AncMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Transparency, Mode=OneWay}"/>
                                        <RadioButton Grid.Column="2" Content="Off" Tag="⊘" Command="{Binding SetAncModeCommand}" CommandParameter="Off" Style="{StaticResource AncToggleButton}" IsChecked="{Binding Device.AncMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Off, Mode=OneWay}"/>
                                    </Grid>
                                    
                                    <!-- ANC Level Selector (Only visible when ANC is On) -->
                                    <StackPanel Margin="20,10,20,0" Visibility="{Binding Device.AncMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=NoiseCancellation}">
                                        <TextBlock Text="Level" Foreground="{StaticResource BrushWhite}" FontSize="12" Margin="0,0,0,5"/>
                                        <UniformGrid Columns="4" Height="40">
                                            <RadioButton Content="High" Style="{StaticResource EqTabButton}" Command="{Binding ApplyAncLevelCommand}" CommandParameter="1" IsChecked="{Binding Device.AncLevel, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=1, Mode=OneWay}"/>
                                            <RadioButton Content="Mid" Style="{StaticResource EqTabButton}" Command="{Binding ApplyAncLevelCommand}" CommandParameter="2" IsChecked="{Binding Device.AncLevel, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=2, Mode=OneWay}" Margin="5,0,0,0"/>
                                            <RadioButton Content="Low" Style="{StaticResource EqTabButton}" Command="{Binding ApplyAncLevelCommand}" CommandParameter="3" IsChecked="{Binding Device.AncLevel, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=3, Mode=OneWay}" Margin="5,0,0,0"/>
                                            <RadioButton Content="Adaptive" Style="{StaticResource EqTabButton}" Command="{Binding ApplyAncLevelCommand}" CommandParameter="5" IsChecked="{Binding Device.AncLevel, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=5, Mode=OneWay}" Margin="5,0,0,0"/>
                                        </UniformGrid>
                                    </StackPanel>

                                    <TextBlock Text="SWITCH BETWEEN NOISE CANCELLATION MODES" Style="{StaticResource DotMatrixText}"/>
                                </StackPanel>
                            </Border>

                            <!-- Equaliser Card -->
                            <Border Style="{StaticResource CardBorder}" Margin="15,20">
                                <StackPanel>
                                    <Grid Margin="20,20,20,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Equaliser" Style="{StaticResource HeadingText}" Margin="0"/>
                                        
                                        <!-- Tabs -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <RadioButton Content="SIMPLE" Style="{StaticResource EqTabButton}" IsChecked="{Binding Device.IsAdvancedEqMode, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" Command="{Binding ToggleAdvancedEqCommand}" CommandParameter="False"/>
                                            <RadioButton Content="ADVANCED" Style="{StaticResource EqTabButton}" Margin="10,0,0,0" IsChecked="{Binding Device.IsAdvancedEqMode, Mode=OneWay}" Command="{Binding ToggleAdvancedEqCommand}" CommandParameter="True"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Simple EQ View -->
                                    <Grid Visibility="{Binding Device.IsAdvancedEqMode, Converter={StaticResource InverseBooleanConverter}}">
                                        <StackPanel>
                                            <!-- Presets -->
                                            <UniformGrid Rows="2" Columns="2" Margin="15,0,15,20">
                                                <RadioButton Content="BALANCED" Command="{Binding SetEqPresetCommand}" CommandParameter="Balanced" Style="{StaticResource EqPresetButton}" IsChecked="{Binding Device.EqPreset, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Balanced, Mode=OneWay}"/>
                                                <RadioButton Content="MORE BASS" Command="{Binding SetEqPresetCommand}" CommandParameter="MoreBass" Style="{StaticResource EqPresetButton}" IsChecked="{Binding Device.EqPreset, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=MoreBass, Mode=OneWay}"/>
                                                <RadioButton Content="MORE TREBLE" Command="{Binding SetEqPresetCommand}" CommandParameter="MoreTreble" Style="{StaticResource EqPresetButton}" IsChecked="{Binding Device.EqPreset, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=MoreTreble, Mode=OneWay}"/>
                                                <RadioButton Content="VOICE" Command="{Binding SetEqPresetCommand}" CommandParameter="Voice" Style="{StaticResource EqPresetButton}" IsChecked="{Binding Device.EqPreset, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Voice, Mode=OneWay}"/>
                                            </UniformGrid>

                                            <!-- Simple Custom 3-Band EQ -->
                                            <controls:CircularEqControl Width="220" Height="220" Margin="15,10,15,10"
                                                                        BassValue="{Binding SimpleEqBass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        MidValue="{Binding SimpleEqMid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        TrebleValue="{Binding SimpleEqTreble, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                            <Button Content="APPLY SIMPLE EQ" Command="{Binding ApplySimpleEqCommand}" Background="{StaticResource BrushRed}" Margin="15,20,15,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Advanced 8-Band EQ View -->
                                    <Grid Visibility="{Binding Device.IsAdvancedEqMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding CustomEqBands}" Margin="15,0,15,10">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel HorizontalAlignment="Center">
                                                            <Slider Orientation="Vertical" Height="150" Minimum="-6" Maximum="6" Value="{Binding Gain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,10"/>
                                                            <TextBlock Text="{Binding Gain, StringFormat={}{0:F0}}" Foreground="{StaticResource BrushWhite}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource BrushLightGray}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Content="APPLY ADVANCED EQ" Command="{Binding ApplyCustomEqCommand}" Background="{StaticResource BrushRed}" Margin="15,20,15,0"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <TextBlock Text="PERSONALISE EQUALISER SETTINGS" Style="{StaticResource DotMatrixText}"/>
                                </StackPanel>
                            </Border>

                            <!-- Audio Enhancements Card -->
                            <Border Style="{StaticResource CardBorder}" Margin="15,20">
                                <StackPanel>
                                    <TextBlock Text="Audio Enhancements" Style="{StaticResource HeadingText}" Margin="20,20,20,25"/>
                                    
                                    <StackPanel Margin="20,10,20,10">
                                        <!-- Spatial Audio -->
                                        <StackPanel Margin="-10,5,-10,25">
                                            <Grid Margin="10,0,10,25">
                                                <TextBlock Text="Spatial audio" Foreground="{StaticResource BrushWhite}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                                                <TextBlock Text="•••" Foreground="{StaticResource BrushWhite}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Right" Cursor="Hand"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <RadioButton Grid.Column="0" GroupName="SpatialAudioModes" Content="Concert mode" Tag="☵" Command="{Binding SetSpatialAudioModeCommand}" CommandParameter="Concert" Style="{StaticResource AncToggleButton}" IsChecked="{Binding Device.SpatialAudioMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Concert, Mode=OneWay}"/>
                                                <RadioButton Grid.Column="1" GroupName="SpatialAudioModes" Content="Cinema mode" Tag="☶" Command="{Binding SetSpatialAudioModeCommand}" CommandParameter="Cinema" Style="{StaticResource AncToggleButton}" IsChecked="{Binding Device.SpatialAudioMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Cinema, Mode=OneWay}"/>
                                                <RadioButton Grid.Column="2" GroupName="SpatialAudioModes" Content="Off" Tag="(○)" Command="{Binding SetSpatialAudioModeCommand}" CommandParameter="Off" Style="{StaticResource AncToggleButton}" IsChecked="{Binding Device.SpatialAudioMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Off, Mode=OneWay}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Bass Enhancer -->
                                        <Border Background="{StaticResource BrushDarkGray}" CornerRadius="20" Padding="25" Margin="0,15,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Bass enhancement" Foreground="{StaticResource BrushWhite}" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding BassEnhancerStateText}" Foreground="{StaticResource BrushLightGray}" FontSize="14" Margin="0,5,0,40"/>
                                                
                                                <Grid Height="30">
                                                    <!-- Custom Tick Marks -->
                                                    <Grid Margin="7,0" VerticalAlignment="Bottom" Height="20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- 0 -->
                                                        <Border Grid.Column="0" HorizontalAlignment="Left" Width="4" Height="4" CornerRadius="2" Background="{StaticResource BrushLightGray}" VerticalAlignment="Bottom" Margin="-2,0,0,3">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding BassEnhancerSliderValue}" Value="0">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <!-- 1 -->
                                                        <Border Grid.Column="0" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 2 -->
                                                        <Border Grid.Column="1" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 3 -->
                                                        <Border Grid.Column="2" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 4 -->
                                                        <Border Grid.Column="3" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 5 -->
                                                        <Border Grid.Column="4" HorizontalAlignment="Right" Width="4" Height="14" CornerRadius="2" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-2,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding BassEnhancerSliderValue}" Value="5">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <!-- 6 -->
                                                        <Border Grid.Column="5" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 7 -->
                                                        <Border Grid.Column="6" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 8 -->
                                                        <Border Grid.Column="7" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 9 -->
                                                        <Border Grid.Column="8" HorizontalAlignment="Right" Width="3" Height="8" CornerRadius="1.5" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-1.5,0"/>
                                                        <!-- 10 -->
                                                        <Border Grid.Column="9" HorizontalAlignment="Right" Width="4" Height="14" CornerRadius="2" Background="#555555" VerticalAlignment="Bottom" Margin="0,0,-2,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding BassEnhancerSliderValue}" Value="10">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Transparent Slider over it -->
                                                    <Slider Minimum="0" Maximum="10" TickFrequency="5" IsSnapToTickEnabled="True"
                                                            Value="{Binding BassEnhancerSliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Style="{StaticResource BassEnhancerSliderStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- High-Quality Audio (LDAC) -->
                                        <Grid Margin="0,15,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="High-Quality Audio" Foreground="{StaticResource BrushWhite}" FontSize="16" FontWeight="SemiBold"/>
                                                <TextBlock Text="Enable LDAC for high-res sound" Foreground="{StaticResource BrushLightGray}" FontSize="12" Margin="0,5,0,0"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1" Style="{StaticResource CustomToggleSwitchStyle}" IsChecked="{Binding Device.HighQualityAudioEnabled}" Command="{Binding ToggleHighQualityAudioCommand}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <TextBlock Text="ENHANCE YOUR AUDIO EXPERIENCE" Style="{StaticResource DotMatrixText}"/>
                                </StackPanel>
                            </Border>

                            <!-- Gestures & Settings Row -->
                            <Grid Margin="15,20,15,40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Background="{StaticResource BrushDarkGray}" CornerRadius="20" Padding="25">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding ShowControlsCommand}" />
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1" />
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" />
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="Controls" Foreground="{StaticResource BrushWhite}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBlock Text="Customised" Foreground="{StaticResource BrushLightGray}" FontSize="14"/>
                                        <TextBlock Text="👆" FontSize="28" Foreground="{StaticResource BrushWhite}" HorizontalAlignment="Left" Margin="0,30,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="{StaticResource BrushDarkGray}" CornerRadius="20" Padding="25">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding ShowSettingsCommand}" />
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.1" />
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.1" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" />
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="Settings" Foreground="{StaticResource BrushWhite}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBlock Text="Firmware &amp; More" Foreground="{StaticResource BrushLightGray}" FontSize="14"/>
                                        <TextBlock Text="⚙" FontSize="28" Foreground="{StaticResource BrushWhite}" HorizontalAlignment="Left" Margin="0,30,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- CONTROLS VIEW -->
                <Grid Visibility="{Binding SelectedDeviceView, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Controls}">
                    <StackPanel>
                        <!-- Header with Back Button -->
                        <Grid Margin="15,10">
                            <Button Content="← Back" HorizontalAlignment="Left" Background="Transparent" Foreground="{StaticResource BrushWhite}" Command="{Binding GoBackToDeviceCommand}"/>
                            <TextBlock Text="Controls" Style="{StaticResource HeadingText}" HorizontalAlignment="Center" Margin="0"/>
                        </Grid>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <Border Style="{StaticResource CardBorder}" Margin="15,10">
                                    <StackPanel Margin="20">
                                        <TextBlock Text="Left Earbud" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Double Tap" Foreground="{StaticResource BrushLightGray}"/>
                                            <ComboBox HorizontalAlignment="Right" Width="120" ItemsSource="{Binding AvailableGestureActions}" SelectedItem="{Binding LeftDoubleTap}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Triple Tap" Foreground="{StaticResource BrushLightGray}"/>
                                            <ComboBox HorizontalAlignment="Right" Width="120" ItemsSource="{Binding AvailableGestureActions}" SelectedItem="{Binding LeftTripleTap}"/>
                                        </Grid>
                                        <Grid>
                                            <TextBlock Text="Long Press" Foreground="{StaticResource BrushLightGray}"/>
                                            <ComboBox HorizontalAlignment="Right" Width="120" ItemsSource="{Binding AvailableGestureActions}" SelectedItem="{Binding LeftLongPress}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <Border Style="{StaticResource CardBorder}" Margin="15,10">
                                    <StackPanel Margin="20">
                                        <TextBlock Text="Right Earbud" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Double Tap" Foreground="{StaticResource BrushLightGray}"/>
                                            <ComboBox HorizontalAlignment="Right" Width="120" ItemsSource="{Binding AvailableGestureActions}" SelectedItem="{Binding RightDoubleTap}"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Triple Tap" Foreground="{StaticResource BrushLightGray}"/>
                                            <ComboBox HorizontalAlignment="Right" Width="120" ItemsSource="{Binding AvailableGestureActions}" SelectedItem="{Binding RightTripleTap}"/>
                                        </Grid>
                                        <Grid>
                                            <TextBlock Text="Long Press" Foreground="{StaticResource BrushLightGray}"/>
                                            <ComboBox HorizontalAlignment="Right" Width="120" ItemsSource="{Binding AvailableGestureActions}" SelectedItem="{Binding RightLongPress}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <Button Content="APPLY CONTROLS" Command="{Binding SyncGesturesCommand}" Margin="15,20,15,30"/>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>

                <!-- SETTINGS VIEW -->
                <Grid Visibility="{Binding SelectedDeviceView, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Settings}">
                    <StackPanel>
                        <Grid Margin="15,10">
                            <Button Content="← Back" HorizontalAlignment="Left" Background="Transparent" Foreground="{StaticResource BrushWhite}" Command="{Binding GoBackToDeviceCommand}"/>
                            <TextBlock Text="Settings" Style="{StaticResource HeadingText}" HorizontalAlignment="Center" Margin="0"/>
                        </Grid>
                        
                        <Border Style="{StaticResource CardBorder}" Margin="15,10">
                            <StackPanel Margin="20">
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Firmware Version" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Device.FirmwareVersion}" Foreground="{StaticResource BrushLightGray}" HorizontalAlignment="Right"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Dual Connection" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <ToggleButton Style="{StaticResource CustomToggleSwitchStyle}" IsChecked="{Binding Device.DualConnectionEnabled}" Command="{Binding ToggleDualConnectionCommand}" HorizontalAlignment="Right"/>
                                </Grid>
                                
                                <ItemsControl ItemsSource="{Binding DualDevices}" Visibility="{Binding DualConnectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,-10,0,20">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="15,5,0,5">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushWhite}" Opacity="0.8"/>
                                                    <TextBlock Text=" (Current)" Foreground="{StaticResource BrushRed}" Visibility="{Binding IsCurrentDevice, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <ToggleButton Style="{StaticResource CustomToggleSwitchStyle}" 
                                                              IsChecked="{Binding IsConnected}" 
                                                              IsEnabled="{Binding IsCurrentDevice, Converter={StaticResource InverseBooleanConverter}}"
                                                              Command="{Binding DataContext.ToggleDualDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              CommandParameter="{Binding}"
                                                              HorizontalAlignment="Right"
                                                              RenderTransformOrigin="0.5,0.5">
                                                    <ToggleButton.RenderTransform>
                                                        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                    </ToggleButton.RenderTransform>
                                                </ToggleButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Low Lag Mode" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <ToggleButton Style="{StaticResource CustomToggleSwitchStyle}" IsChecked="{Binding Device.LowLatencyMode}" Command="{Binding ToggleLowLatencyCommand}" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Find My Earbuds" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Command="{Binding FindEarbudsCommand}" Background="{StaticResource BrushDarkGray}" Foreground="{StaticResource BrushLightGray}" Padding="15,5" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Content" Value="PLAY SOUND"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFinding}" Value="True">
                                                        <Setter Property="Content" Value="STOP SOUND"/>
                                                        <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                                
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Standby Auto Power-Off" Foreground="{StaticResource BrushWhite}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ComboBox Width="120"
                                                  ItemsSource="{Binding AutoPowerOffOptions}" 
                                                  DisplayMemberPath="Display" SelectedValuePath="Value" 
                                                  SelectedValue="{Binding Device.AutoPowerOffTime}">
                                        </ComboBox>
                                        <Button Content="APPLY" Command="{Binding ApplyAutoPowerOffCommand}" Background="{StaticResource BrushDarkGray}" Foreground="{StaticResource BrushLightGray}" Padding="15,5" BorderThickness="0" Cursor="Hand" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Button Content="DISCONNECT" Background="{StaticResource BrushDarkGray}" Foreground="{StaticResource BrushRed}" BorderThickness="1" BorderBrush="{StaticResource BrushRed}" Command="{Binding DisconnectDeviceCommand}" Margin="0,20,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>

